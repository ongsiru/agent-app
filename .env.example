# Copy to .env and fill in whichever providers you want to use.
# You do NOT need every provider enabled on day one.

# ---------- OpenAI ----------
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_GENERAL_MODEL=gpt-5.4
OPENAI_CODEX_MODEL=gpt-5.3-codex

# ---------- Anthropic ----------
ANTHROPIC_API_KEY=
ANTHROPIC_CLAUDE_MODEL=claude-sonnet-4-6

# ---------- Google Gemini ----------
GEMINI_API_KEY=
GOOGLE_GEMINI_MODEL=gemini-3.1-pro-preview

# ---------- Runtime ----------
MAX_ITERATIONS=3
AUTO_MAX_ITERATIONS_SAFETY_CAP=12
COMMAND_TIMEOUT_MS=600000
RUNS_DIR=./runs
CLONES_DIR=./workspaces/cloned-repos

# MAX_ITERATIONS can be a number like 3 or the string auto.
# In auto mode, the manager keeps iterating until acceptance,
# but AUTO_MAX_ITERATIONS_SAFETY_CAP still stops runaway loops.
#
# Optional: override the default QA commands if you want.
# QA_COMMANDS=npm run lint|npm test|npm run build
